# Default environment template for this frontend.
# Copy values into `.env.development` for local machine-specific setup.
# Production values should be configured on the hosting platform.

# API config
VITE_API_BASE_URL=
VITE_PROD_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080
VITE_DEV_SERVER_PORT=5173

# Cognito auth config
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_REGION=
VITE_COGNITO_USER_POOL_CLIENT_ID=
VITE_COGNITO_BACKEND_TOKEN_USE=access
